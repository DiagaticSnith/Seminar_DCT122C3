generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/tracking"
}

datasource db {
  provider = "postgresql"
}

enum FoodStatus {
  PENDING
  APPROVED
}

model MasterFood {
  id              String     @id @default(uuid())
  name            String
  baseServingSize Float
  baseCalories    Float
  baseProtein     Float
  baseCarbs       Float
  baseFat         Float
  status          FoodStatus @default(APPROVED)
}

model MasterExercise {
  id          String   @id @default(uuid())
  name        String
  category    String
  tags        String[]
  youtubeLink String?
}
